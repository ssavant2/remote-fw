# ===========================================================================
# REMOTE FIREWALL - Production Environment Configuration
# ===========================================================================
#
# SETUP:
# 1. Download this file as .env.
# 2. Fill in all CHANGE_ME values.
# 3. Start the app:   docker compose up -d
#
# NOTE: After .env changes, use "docker compose up -d" instead of restart.
# ===========================================================================

# ---------------------------------------------------------------------------
# SOPHOS FIREWALL / SFOS
# ---------------------------------------------------------------------------
SFOS_HOST=CHANGE_ME_firewall_hostname_or_ip
# Optional, used with docker-compose.override.yml if container DNS cannot resolve SFOS_HOST.
# SFOS_EXTRA_HOST_IP=192.0.2.10
SFOS_PORT=4444
SFOS_USERNAME=CHANGE_ME_api_user
SFOS_PASSWORD=CHANGE_ME_password

# Set to true only if the container trusts the firewall certificate chain.
SFOS_VERIFY_TLS=false

# SFOS can be slow to respond under load. Keep this reasonably high.
SFOS_TIMEOUT=120

# ---------------------------------------------------------------------------
# FIREWALL RULES
# ---------------------------------------------------------------------------
# Comma-separated SFOS firewall rule names. Names must match SFOS exactly.
RULE_NAMES=CHANGE_ME_rule_name_1,CHANGE_ME_rule_name_2

# Optional fallback for repairing a rule that has already fallen out of its
# group when using the XML fallback method:
# RULE_GROUPS=Rule Name=Rule Group Name

# Default and recommended method. Uses the same internal SFOS web-console
# endpoint as the GUI enable/disable button.
SFOS_TOGGLE_METHOD=gui

# ---------------------------------------------------------------------------
# WEB APP
# ---------------------------------------------------------------------------
APP_TITLE=Remote Firewall

# Bind to 127.0.0.1 when using a local reverse proxy on the same host.
# Use 0.0.0.0 only if you intentionally want direct LAN access.
REMOTE_FW_BIND=127.0.0.1
REMOTE_FW_PORT=8090

# ---------------------------------------------------------------------------
# IMAGE VERSION
# ---------------------------------------------------------------------------
# Pin to a release version, or use "latest" for newest.
REMOTE_FW_VERSION=latest
