SFOS_HOST=firewall.example.local
# Optional, used by docker-compose.override.yml.example if container DNS cannot resolve SFOS_HOST.
SFOS_EXTRA_HOST_IP=192.0.2.10
SFOS_PORT=4444
SFOS_USERNAME=api-user
SFOS_PASSWORD=change-me
SFOS_VERIFY_TLS=false
SFOS_TIMEOUT=120

RULE_NAMES=Example Firewall Rule,Another Example Rule
# Optional fallback for repairing a rule that has already fallen out of its group:
# RULE_GROUPS=Example Firewall Rule=Example Rule Group
APP_TITLE=Remote Firewall
REMOTE_FW_BIND=127.0.0.1
REMOTE_FW_PORT=8090
REMOTE_FW_MAX_CONTENT_LENGTH=16384
# Optional, comma-separated origins allowed to POST if Host differs from Origin.
# REMOTE_FW_ALLOWED_ORIGINS=https://remote-fw.example.local,http://docker1:8090
